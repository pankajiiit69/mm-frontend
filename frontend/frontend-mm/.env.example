# Matrimony backend base URL
VITE_API_BASE_URL=https://localhost:8086

# Request timeout in milliseconds
VITE_REQUEST_TIMEOUT_MS=30000

# Use backend APIs by default; set true only for mock mode
VITE_USE_MOCK_API=false

# Optional: Google OAuth client ID for social login
VITE_GOOGLE_CLIENT_ID=

# Dev/preview server port (optional)
VITE_PORT=9086

# ── HTTPS ─────────────────────────────────────────────────────────────────────
# Set to true to enable HTTPS for the Vite dev/preview server.
VITE_HTTPS=true
VITE_HTTPS_KEY_FILE=certs/key.pem
VITE_HTTPS_CERT_FILE=certs/cert.pem
