{
  "name": "frontend-mm",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:all": "npm run build --prefix ../auth-core && npm run build",
    "build:all:clean": "npm run clean && npm run build:all",
    "build:all:clean:hard": "npm run clean:hard && npm run build:all",
    "install:build:all": "npm install  --prefix ../auth-core && npm run build --prefix ../auth-core && npm install && npm run build",
    "clean": "rimraf dist",
    "clean:hard": "rimraf dist node_modules",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fruzoos/auth-core": "file:../auth-core",
    "@react-oauth/google": "^0.13.4",
    "axios": "^1.14.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "rimraf": "^6.1.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.3"
  }
}
